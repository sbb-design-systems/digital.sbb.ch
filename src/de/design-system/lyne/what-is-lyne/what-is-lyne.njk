<sbb-overlay expanded trigger="overlay-trigger">

  {% from "lane.njk" import lane %}

  <sbb-title level="2" visual-level="3" class="roadmap__title">{{ lyne.roadmap.title }}</sbb-title>

  <div class="roadmap">
    {# --- Achse: Jahres-Band --- #}
    <div class="roadmap__axis roadmap__axis--years"
           style="--roadmap-cols: {{ lyne.roadmap.columnCount }};"
           aria-hidden="true">
      {% for band in lyne.roadmap.yearBands %}
        <div class="roadmap__year sbb-text-xxs sbb-text--bold" style="grid-column: {{ band.gridColumn }};">
          {{ band.year }}
        </div>
      {% endfor %}
    </div>

    {# --- Achse: Quartals-Ticks --- #}
    <div class="roadmap__axis roadmap__axis--quarters"
           style="--roadmap-cols: {{ lyne.roadmap.columnCount }};"
           aria-hidden="true">
      {% for tick in lyne.roadmap.quarterTicks %}
        <div class="roadmap__quarter sbb-text-xxs" style="grid-column: {{ tick.gridColumn }};">
          {{ tick.label }}
        </div>
      {% endfor %}
    </div>

    {# --- Swimlanes --- #}
    {% for l in lyne.roadmap.lanes %}
      {{ lane(l, lyne.roadmap.columnCount) }}
    {% endfor %}
  </div>

  <div class="sbb-screen-reader-only">
    <summary>Roadmap als Liste</summary>
    {% for l in lyne.roadmap.lanes %}
      <h3>{{ l.title }}</h3>
      {% if l.items.length %}
        <ul>
          {% for item in l.items %}
            <li>
              <strong>{{ item.title }}</strong> –
              {{ item.rangeLabel }}
              {% if item.type == 'planned' %} (geplant){% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p>
          <em>Laufend</em>
        </p>
      {% endif %}
    {% endfor %}
  </div>

</sbb-overlay>